# --- Internal-only files (NEVER push) ---
WORKLOG.md
*_local.*
.notes/
NOTES.md
TODO.md

# --- Paper drafts and rendered PDFs (live on arXiv, not in this repo) ---
draft_*.md
*.pdf

# --- Figures (live in the arXiv paper, not in this repo) ---
figures/

# --- Experiment outputs (regenerated by running the code) ---
# Numbers and figures are reported in the arXiv paper; the repo ships code only.
results/
code/results/
exports/

# --- Full dataset / personal data ---
# Public repos publish algorithm framework only — no data of any kind.
data/

# --- Trained model binaries (may contain stale layer names) ---
*.h5
*.keras
*.pkl
*.pickle
*.pb
saved_model/

# CoreML / TFLite: keep one representative export, gitignore the rest
# (Adjust per your decision on what to ship in exports/.)
exports/*_local.mlpackage
exports/*_local.tflite

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.coverage
htmlcov/

# --- Virtual envs ---
venv/
.venv/
env/
ENV/

# --- IDE / OS ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Secrets ---
.env
.env.*
*.pem
*.key
*_credentials.json
secrets/

# --- Logs ---
*.log
logs/
